      "toolArgs": [
        "--dart-define=SONGBRIEF_AD_MODE=admobTest"
      ]
    },
    {
      "name": "SongBrief Mobile - AdMob Test",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": [
        "--dart-define=SONGBRIEF_AD_MODE=admobTest"
      ]
    },
    {
      "name": "SongBrief Mobile - Premium Preview",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
